<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Login LogoArtCR</title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      background-color: #f4f4f4;
    }

    #frame-login {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: none;
    }
  </style>
</head>
<body>

  <iframe id="frame-login" src=""></iframe>

  <script>
    const urlParams = new URLSearchParams(window.location.search);

    const idProyecto = (urlParams.get('id') || '').trim();
    const usuario = (urlParams.get('usuario') || '').trim();

    let urlFinal = "https://script.google.com/macros/s/AKfycbzvemCl24Ug0TAG4jyDKBN8hcbrhmhm7jWHhtS0XbG_unSKNJL8nYKY2Yqhm_vW8_GY3Q/exec";

    const parametros = [];

    if (idProyecto) {
      parametros.push("id=" + encodeURIComponent(idProyecto));
    }

    if (usuario) {
      parametros.push("usuario=" + encodeURIComponent(usuario));
    }

    if (parametros.length > 0) {
      urlFinal += "?" + parametros.join("&");
    }

    document.getElementById('frame-login').src = urlFinal;
  </script>

</body>
</html>
